---
const services = [
  { title: "Strzyżenie Klasyczne", price: "80 PLN", desc: "Konsultacja, mycie, strzyżenie i stylizacja dopasowana do kształtu twarzy." },
  { title: "Strzyżenie Brody", price: "60 PLN", desc: "Formowanie brody z użyciem brzytwy i gorącego ręcznika, pielęgnacja olejkami." },
  { title: "Combo (Włosy + Broda)", price: "130 PLN", desc: "Kompleksowa usługa strzyżenia włosów i brody. Relaks i pełne odświeżenie." },
  { title: "Golenie Brzytwą", price: "70 PLN", desc: "Tradycyjne golenie z wykorzystaniem gorących kompresów i kosmetyków premium." },
  { title: "Tuszowanie Siwizny", price: "50 PLN", desc: "Dyskretne przykrycie siwych włosów lub brody naturalnymi preparatami." },
  { title: "Strzyżenie Ojciec + Syn", price: "140 PLN", desc: "Wspólny czas i świetne fryzury dla Ciebie i Twojego młodego dżentelmena." }
];
---

<section id="uslugi" class="py-24 bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="flex items-center justify-center space-x-3 text-amber-500 mb-4">
        <span class="h-0.5 w-8 bg-amber-500"></span>
        <span class="font-oswald tracking-widest uppercase text-sm font-semibold">Cennik</span>
        <span class="h-0.5 w-8 bg-amber-500"></span>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold font-oswald mb-4 uppercase text-white">Nasze <span class="text-amber-500">Usługi</span></h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-2xl hover:border-amber-500/50 transition-all duration-300 group relative overflow-hidden">
          <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
             <svg class="w-16 h-16 text-amber-500" fill="currentColor" viewBox="0 0 24 24"><path d="M19 12h2v10h-2v-10zm-2-2h-10v12h10v-12zm-11 2h-2v10h2v-10zm11-6h-10v2h10v-2zm-12 0h-2v2h2v-2zm14 0h-2v2h2v-2z"/></svg>
          </div>
          
          <div class="flex justify-between items-baseline mb-4 relative z-10">
            <h3 class="text-2xl font-bold font-oswald uppercase tracking-tight group-hover:text-amber-500 transition-colors">{service.title}</h3>
            <span class="text-amber-500 font-oswald font-bold text-xl ml-4 whitespace-nowrap">{service.price}</span>
          </div>
          <p class="text-zinc-400 leading-relaxed font-medium relative z-10">
            {service.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>