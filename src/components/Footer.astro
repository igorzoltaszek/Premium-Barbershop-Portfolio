<footer id="kontakt" class="bg-zinc-900 border-t border-zinc-800 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <h3 class="text-2xl font-bold tracking-tighter mb-6">
          CUT<span class="text-amber-500">&</span>SHAVE
        </h3>
        <p class="text-zinc-400">
          Miejsce stworzone dla mężczyzn, którzy cenią sobie świetny wygląd i profesjonalną obsługę. Więcej niż fryzjer.
        </p>
      </div>
      
      <div>
        <h4 class="text-lg font-bold mb-6 text-zinc-100">Godziny otwarcia</h4>
        <ul class="space-y-3 text-zinc-400">
          <li class="flex justify-between"><span>Poniedziałek - Piątek</span> <span>09:00 - 20:00</span></li>
          <li class="flex justify-between"><span>Sobota</span> <span>09:00 - 15:00</span></li>
          <li class="flex justify-between text-zinc-500"><span>Niedziela</span> <span>Zamknięte</span></li>
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-bold mb-6 text-zinc-100">Lokalizacja & Kontakt</h4>
        <ul class="space-y-3 text-zinc-400">
          <li>ul. Przykładowa 12/4</li>
          <li>00-000 Warszawa</li>
          <li class="pt-2">
            <a href="tel:+48123456789" class="hover:text-amber-500 transition-colors">+48 123 456 789</a>
          </li>
          <li>
            <a href="mailto:hello@cutshave.pl" class="hover:text-amber-500 transition-colors">hello@cutshave.pl</a>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-zinc-800 pt-8 flex flex-col md:flex-row justify-between items-center text-sm text-zinc-500">
      <p>&copy; {new Date().getFullYear()} Cut & Shave Barbershop. Wszelkie prawa zastrzeżone.</p>
      <div class="mt-4 md:mt-0 flex space-x-4">
        <a href="#" class="hover:text-zinc-300">Instagram</a>
        <a href="#" class="hover:text-zinc-300">Facebook</a>
      </div>
    </div>
  </div>
</footer>